\documentclass[11pt,letterpaper]{article}

%% ── Encoding & Fonts ──────────────────────────────────────────
\usepackage{fontspec}
\setsansfont{Libertinus Sans}
\setmainfont{Avenir Next}
\renewcommand{\familydefault}{\sfdefault}
\newfontfamily\sectionfont{Libertinus Sans}
\newfontfamily\detailfont{Avenir Next}

%% ── Layout ────────────────────────────────────────────────────
\usepackage[total={6.5in, 9.3in}]{geometry}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}

%% ── Colors ────────────────────────────────────────────────────
\usepackage{xcolor}
\definecolor{mainColor}{rgb}{0.341,0.4588,0.3961}
\definecolor{accentColor}{rgb}{0.9686,0.7098,0.0706}
\definecolor{linkColor}{rgb}{0.2470,0.4235,0.7098}
\definecolor{grayColor}{rgb}{0.4588,0.476,0.4824}

%% ── Links ─────────────────────────────────────────────────────
\usepackage[unicode]{hyperref}
\hypersetup{
  colorlinks=true,
  urlcolor=linkColor,
  linkcolor=linkColor,
}

%% ── Multi-column ──────────────────────────────────────────────
\usepackage{multicol}
\setlength{\columnsep}{1.5em}

%% ── Tabular ───────────────────────────────────────────────────
\usepackage{array}
\usepackage{longtable}
\usepackage{calc}
\usepackage{ragged2e}

%% ── Page numbers ──────────────────────────────────────────────
\usepackage{fancyhdr}
\usepackage{lastpage}
\pagestyle{fancy}
\renewcommand{\headrulewidth}{0pt}
\fancyhf{}
\fancyfoot[R]{\small\itshape\color{grayColor}\thepage/\pageref{LastPage}}

%% ── Lengths ───────────────────────────────────────────────────
\newlength{\hintscolwidth}
\setlength{\hintscolwidth}{0.175\textwidth}
\newlength{\sepcolwidth}
\setlength{\sepcolwidth}{0.025\textwidth}
\newlength{\maincolwidth}
\setlength{\maincolwidth}{\textwidth-\hintscolwidth-\sepcolwidth}

%% ── Custom commands ───────────────────────────────────────────

% Placeholder text written by Claude — bright red, flags "review/rewrite me".
% Authored in the data as @@...@@ (converted to \claude{} at build time).
\definecolor{claudeColor}{rgb}{0.90,0.10,0.10}
\newcommand{\claude}[1]{{\color{claudeColor}#1}}

% Section heading: gold bar on the left, title in Libertinus Sans
\newlength{\baseletterht}
\settoheight{\baseletterht}{{\sectionfont\LARGE o}}
\addtolength{\baseletterht}{-0.95ex}
\newlength{\subbarht}
\settoheight{\subbarht}{{\sectionfont\Large o}}
\addtolength{\subbarht}{-0.95ex}
\newcommand{\cvsection}[1]{%
  \par\addvspace{2.5ex}%
  \parbox[t]{\hintscolwidth}{\strut\raggedleft\raisebox{\baseletterht}{\color{accentColor}\rule{\hintscolwidth}{0.95ex}}}%
  \hspace{\sepcolwidth}%
  \parbox[t]{\maincolwidth}{\strut{\sectionfont\LARGE\bfseries\color{mainColor}#1}}%
  \par\nobreak\addvspace{1ex}%
}

% Group heading: large gray text spanning the page, no bar or rule
\newcommand{\cvgroup}[1]{%
  \par\addvspace{5.5ex}%
  {\sectionfont\fontsize{20pt}{24pt}\selectfont\bfseries\color{grayColor}#1}%
  \par\nobreak\addvspace{0.5ex}%
}

% Subsection heading: small green square in the hint column echoing the gold bar
\newcommand{\cvsubsection}[1]{%
  \par\addvspace{2.4ex}%
  \parbox[t]{\hintscolwidth}{\strut\raggedleft\raisebox{\subbarht}{\color{mainColor}\rule{0.95ex}{0.95ex}}}%
  \hspace{\sepcolwidth}%
  \parbox[t]{\maincolwidth}{\strut{\sectionfont\Large\bfseries\color{grayColor}#1}}%
  \par\nobreak\addvspace{0.5ex}%
}

% Optional context paragraph under a section or subsection heading.
% Italic, sits in the main column (hint column blank) so it lines up with the
% entries: pulled up close to the heading, with a slight gap before the list.
\newcommand{\cvintro}[1]{%
  \vspace{-1.2ex}%
  \begingroup\leftskip=0.5\hintscolwidth\relax
  {\itshape\color{grayColor}\RaggedRight #1\par}%
  \endgroup
  \addvspace{1.1ex}%
}

% Single CV entry: \cvitem{year}{content}
\newcommand{\cvitem}[3][0.25em]{%
  \begin{tabular}{@{}p{\hintscolwidth}@{\hspace{\sepcolwidth}}>{\RaggedRight\arraybackslash}p{\maincolwidth}@{}}%
    \raggedleft\small #2 & #3%
  \end{tabular}%
  \par\addvspace{#1}%
}

%% ── Document ──────────────────────────────────────────────────
\begin{document}

%% ── Header ────────────────────────────────────────────────────
{\sectionfont\fontsize{36pt}{42pt}\selectfont\bfseries\color{mainColor} STEVE\,\,TRETTEL}\\[0.6em]
{\color{grayColor}\slshape \href{mailto:strettel@usfca.edu}{strettel@usfca.edu}\quad \href{https://stevejtrettel.site}{stevejtrettel.site}\quad \href{https://github.com/stevejtrettel}{github.com/stevejtrettel}\hfill << date >>}

\vspace{2.5em}

%% ── Appointments ──────────────────────────────────────────────
\cvsection{Appointments}
<% for e in appointments %>
\cvitem{<< e.years >>}{\textbf{<< e.institution >>}, \textit{<< e.role >>}.}
<% endfor %>

%% ── Institute Visits ──────────────────────────────────────────
\cvsection{Research Residencies}
<% for e in instituteVisits %>
\cvitem{<< e.years >>}{\textbf{<< e.institution >>}, << e.location >>.<%- if e.detail %>\newline {\detailfont\small << e.detail >>}<% endif %>}
<% endfor %>

%% ── Education ─────────────────────────────────────────────────
\cvsection{Education}
<% for e in education %>
\cvitem{<< e.years >>}{\textbf{<< e.institution >>}, \textit{<< e.degree >>}<%- if e.detail %>, << e.detail | replace("Advisor:", "Advisor:") >><% endif %>.}
<% endfor %>

%% ── Research & Creative Work group ────────────────────────────
\cvgroup{Research \& Creative Work}
<% if intros.researchCreativeWork %>\cvintro{<< intros.researchCreativeWork >>}<% endif %>

%% ── Publications ──────────────────────────────────────────────
\cvsection{Publications}
<% if intros.publications %>\cvintro{<< intros.publications >>}<% endif %>

\cvsubsection{Peer-Reviewed Articles}
<% for e in publications %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.coauthors %>, \textit{with << e.coauthors | join(", ") >>}<% endif %>.<%- if e.url %> Published in \href{<< e.url >>}{<< e.venue >>}<%- if e.arxiv %> (\href{<< e.arxiv >>}{arXiv version})<% endif %>.<%- elif e.venue %> << e.venue >><%- if e.arxiv %> (\href{<< e.arxiv >>}{arXiv version})<% endif %>.<%- elif e.arxiv %> \href{<< e.arxiv >>}{arXiv preprint}.<% endif %>}
<% endfor %>

\cvsubsection{Invited Contributions}
<% for e in invited %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.coauthors %>, \textit{with << e.coauthors | join(", ") >>}<% endif %>.<%- if e.url %> Published in \href{<< e.url >>}{<< e.venue >>}<%- if e.arxiv %> (\href{<< e.arxiv >>}{arXiv version})<% endif %>.<%- elif e.venue %> << e.venue >><%- if e.arxiv %> (\href{<< e.arxiv >>}{arXiv version})<% endif %>.<%- elif e.arxiv %> \href{<< e.arxiv >>}{arXiv preprint}.<% endif %>}
<% endfor %>

%% ── Preprints & Work in Progress ──────────────────────────────
\cvsubsection{Preprints \& Work in Progress}
<% if intros.inProgress %>\cvintro{<< intros.inProgress >>}<% endif %>
<% for e in inProgress %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.coauthors and e.coauthors | length %>, \textit{with << e.coauthors | join(", ") >>}<% endif %>.<%- if e.url %> Available at \href{<< e.url >>}{<< e.url | replace("https://", "") >>}<%- if e.arxiv %> (\href{<< e.arxiv >>}{arXiv version})<% endif %>.<%- elif e.arxiv %> Available at \href{<< e.arxiv >>}{<< e.arxiv | replace("https://", "") >>}.<% endif %><%- if e.venue %>\newline << e.venue >><% endif %>}
<% endfor %>

%% ── Art Exhibitions ───────────────────────────────────────────
\cvsection{Art Exhibitions}
<% if intros.exhibitions %>\cvintro{<< intros.exhibitions >>}<% endif %>
<% for e in exhibitions %>
\cvitem{<< e.year >>}{\textbf{<< e.venue >>}, \textit{<< e.title >>}<%- if e.collaborators %>, with << e.collaborators | join(", ") >><% endif %><%- if e.detail %>. << e.detail >><% endif %><%- if e.juror %>. Juror: << e.juror >><% endif %>.<%- if e.url %> {\detailfont\small\href{<< e.url >>}{exhibition details}}<% endif %>}
<% endfor %>

%% ── Film ──────────────────────────────────────────────────────
\cvsection{Film}
<% for e in film %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.role %>, << e.role >><% endif %>.<%- if e.detail %>\newline {\detailfont\small << e.detail >><%- if e.url %> \href{<< e.url >>}{watch the trailer}<% endif %>}<% endif %>}
<% endfor %>

%% ── Software ──────────────────────────────────────────────────
\cvsection{Mathematical Software}
<% if intros.software %>\cvintro{<< intros.software >>}<% endif %>

\cvsubsection{Software Systems}
<% if intros.softwareSystems %>\cvintro{<< intros.softwareSystems >>}<% endif %>
<% for e in software.systems %>
\cvitem{}{\textbf{<< e.title >>}<%- if e.collaborators %>, with << e.collaborators | join(", ") >><% endif %>.<%- if e.url %> \href{<< e.url >>}{See Code on GitHub}.<% endif %>\newline {\detailfont\small << e.description >><%- if e.detail %> << e.detail >><% endif %>}}
<% endfor %>

\cvsubsection{Research Projects}
<% if intros.researchProjects %>\cvintro{<< intros.researchProjects >>}<% endif %>
<% for e in software.projects %>
\cvitem{}{\textbf{<< e.title >>}<%- if e.collaborators %>, with << e.collaborators | join(", ") >><% endif %>.<%- if e.url %> \href{<< e.url >>}{See Code on GitHub}.<% endif %>\newline {\detailfont\small << e.description >><%- if e.detail %> << e.detail >><% endif %>}}
<% endfor %>

<# Specific Programs section hidden — data retained in software.yaml, not displayed #>

%% ── Featured Work ─────────────────────────────────────────────
\cvsection{Featured Work}
<% for e in featuredWork %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.collaborators %>, with << e.collaborators | join(", ") >><% endif %><%- if e.detail %>. \textit{<< e.detail >>}<% endif %><%- if e.venue %>. Published in <% if e.url %>\href{<< e.url >>}{<< e.venue >>}<% else %><< e.venue >><% endif %><% endif %>.}
<% endfor %>

%% ── Teaching group ────────────────────────────────────────────
\cvgroup{Teaching}
<% if intros.teaching %>\cvintro{<< intros.teaching >>}<% endif %>

%% ── Course Notes ──────────────────────────────────────────────
\cvsection{Course Notes \& Book Drafts}
<% for e in courseNotes %>
\cvitem{<< e.number | default("") >>}{\textbf{<< e.title >>}<%- if e.pages %> (<< e.pages >> pages)<% endif %><%- if e.url %>. \href{<< e.url >>}{<< e.url | replace("https://", "") >>}<% endif %><%- if e.detail %>.\newline {\detailfont\small << e.detail >>}<% else %>.<% endif %>}
<% endfor %>

%% ── Teaching ──────────────────────────────────────────────────
\cvsection{Teaching Experience}
<% for uni in teaching %>
\cvsubsection{<< uni.university >>}
<% for c in uni.courses %>
<% if uni.university == "University of San Francisco" %>
\cvitem{<< c.terms | default("") >>}{\textbf{<< c.name >>} (<< c.number >>), << c.level >>.}
<% else %>
\cvitem{}{\textbf{<< c.name >>} (<< c.number >>), << c.level >>.}
<% endif %>
<% endfor %>
<% endfor %>

%% ── Talks group ───────────────────────────────────────────────
\cvgroup{Talks}
<% if intros.talks %>\cvintro{<< intros.talks >>}<% endif %>

%% ── Public Lectures ───────────────────────────────────────────
\cvsection{Invited Lectures}
<% for e in publicLectures %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.event %>, << e.event >><% endif %>.\newline {\detailfont\small << e.institution >><%- if e.location %>, << e.location >><% endif %><%- if e.url %>. \href{<< e.url >>}{video}<% endif %>}}
<% endfor %>

%% ── Seminars & Colloquia (2-column, compact) ──────────────────
\cvsection{Seminars, Colloquia \& Conferences}
<% if intros.researchTalks %>\cvintro{<< intros.researchTalks >>}<% endif %>
\begin{multicols}{2}
\raggedright
<% for e in researchTalks %>
{\small\color{grayColor}<< e.year >>}\enspace\textbf{<< e.institution >>}<%- if e.url %>\enspace{\detailfont\small\href{<< e.url >>}{video}}<% endif %>\par\addvspace{0.4em}
<% endfor %>
\end{multicols}

%% ── Undergraduate Talks (2-column, compact) ───────────────────
\cvsection{Undergraduate Talks}
<% if intros.colloquia %>\cvintro{<< intros.colloquia >>}<% endif %>
\begin{multicols}{2}
\raggedright
<% for e in colloquia %>
{\small\color{grayColor}<< e.year >>}\enspace\textbf{<< e.institution >>}<%- if e.url %>\enspace{\detailfont\small\href{<< e.url >>}{video}}<% endif %>\par\addvspace{0.4em}
<% endfor %>
\end{multicols}

%% ── Service group ─────────────────────────────────────────────
\cvgroup{Service}
<% if intros.service %>\cvintro{<< intros.service >>}<% endif %>

%% ── Department & University ───────────────────────────────────
\cvsection{Department \& University}
<% for e in service.departmentUniversity %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.institution %>, << e.institution >><% endif %><%- if e.detail %>.\newline {\detailfont\small << e.detail >>}<% endif %>.}
<% endfor %>

%% ── Mathematical Community ────────────────────────────────────
\cvsection{Mathematical Community}

\cvsubsection{Graduate Student Mentoring}
\cvitem{}{\textit{<< mentoring.intro >>}}
<% for s in mentoring.students %>
\cvitem{<< s.years >>}{\textbf{<< s.name >>} (<< s.institution >>), << s.degree >>.<%- if s.thesis %>\newline {\detailfont\small Thesis: << s.thesis >>}<% endif %>}
<% endfor %>

\cvsubsection{Refereeing \& Peer Review}
<% if refereeing.journals and refereeing.journals | length %>\cvitem{Journals}{<< refereeing.journals | join(", ") >>.}<% endif %>
<% if refereeing.conferences and refereeing.conferences | length %>\cvitem{Conferences}{<< refereeing.conferences | join(", ") >>.}<% endif %>
<% if refereeing.books and refereeing.books | length %>\cvitem{Book Manuscripts}{<< refereeing.books | join(", ") >>.}<% endif %>

\cvsubsection{Outreach}
\cvitem{}{\textit{I regularly give public lectures to a wide range of audiences---from grade-school students to retirees---catalogued in the Talks section above.}}
<% for e in service.mathematicalCommunity %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.institution %>, << e.institution >><% endif %><%- if e.detail %>.\newline {\detailfont\small << e.detail >>}<% endif %>.}
<% endfor %>

%% ── Other group ───────────────────────────────────────────────
\cvgroup{Other}
<% if intros.other %>\cvintro{<< intros.other >>}<% endif %>

%% ── Awards ────────────────────────────────────────────────────
\cvsection{Fellowships \& Awards}
<% for e in awards %>
\cvitem{<< e.year >>}{\textbf{<< e.title >>}<%- if e.institution %>, << e.institution >><% endif %><%- if e.detail %>.\newline {\detailfont\small << e.detail >>}<% endif %>.}
<% endfor %>

%% ── Languages ─────────────────────────────────────────────────
\cvsection{Languages}
<% for e in languages %>
\cvitem{}{\textbf{<< e.language >>}, << e.level >>.}
<% endfor %>

\end{document}
